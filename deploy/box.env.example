# Deployment parameters for bootstrap.sh. Copy to box.env and edit.

# Domain that points at this VM (Caddy gets the TLS cert for it)
DOMAIN=oura-mcp.example.duckdns.org

# Where the app lives and which user runs it
APP_DIR=/home/ubuntu/oura-mcp
APP_USER=ubuntu

# Port the Node server listens on (Caddy proxies to it)
PORT=3000

# Optional: OCI Vault OCID for secret fetching at service start.
# Leave empty to use a plain .env file in APP_DIR instead.
VAULT_OCID=
