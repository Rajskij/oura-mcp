# Oura OAuth app credentials (cloud.ouraring.com -> API Applications)
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Long random path segment for the MCP endpoint.
# Generate with: openssl rand -hex 24
MCP_PATH_SECRET=

PORT=3000

# Optional, for development: set to 1 to serve Oura's sandbox (fake data,
# no account/subscription/tokens needed). Client id/secret can be any string.
# OURA_SANDBOX=1
