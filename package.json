{
  "name": "oura-mcp",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "bin": {
    "oura-mcp": "dist/src/stdio.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:stdio": "tsx scripts/smoke-stdio.ts",
    "get-token": "tsx scripts/get-token.ts"
  },
  "dependencies": {
    "@hono/mcp": "^0.3.1",
    "@hono/node-server": "^2.0.8",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "hono": "^4.12.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^22.20.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
