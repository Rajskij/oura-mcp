{
  "name": "oura-mcp",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "bin": {
    "oura-mcp": "dist/src/stdio.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "start": "node dist/src/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:stdio": "tsx scripts/smoke-stdio.ts",
    "get-token": "tsx scripts/get-token.ts",
    "worker:dev": "wrangler dev",
    "worker:check": "wrangler deploy --dry-run --outdir /tmp/oura-mcp-worker"
  },
  "dependencies": {
    "@hono/mcp": "^0.3.0",
    "@hono/node-server": "^2.0.8",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "hono": "^4.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^22.0.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  },
  "cloudflare": {
    "label": "oura-mcp",
    "products": [
      "Workers",
      "Durable Objects"
    ],
    "categories": [
      "ai"
    ],
    "bindings": {
      "MCP_PATH_SECRET": {
        "description": "A long random string that guards your endpoint (it becomes part of the URL). Generate one with `openssl rand -hex 24`. **Leave every field empty to deploy a demo with fake sample data.**"
      },
      "OURA_CLIENT_ID": {
        "description": "Client ID of your own free Oura app from [developer.ouraring.com/applications](https://developer.ouraring.com/applications). Leave empty for demo mode."
      },
      "OURA_CLIENT_SECRET": {
        "description": "Client secret of the same Oura app. After deploying, set its redirect URI to `https://<your-worker-url>/oauth/callback`."
      }
    }
  }
}
